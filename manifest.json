{
  "manifest_version": 3,
  "name": "Tab Buster",
  "version": "0.1.0",
  "description": "Too many tabs open? Time to bust them away! Group them, zap them, bust them away.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["tabs", "favicon"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
